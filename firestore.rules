rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        || exists(/databases/$(database)/documents/admin/$(request.auth.uid))
      );
    }

    function hasUserProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function requesterProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function requesterUserId() {
      return requesterProfile().userId;
    }

    function requesterDisplayName() {
      return requesterProfile().nicknameNoun + "#" + requesterProfile().nicknameTag;
    }

    function signedInWithGoogle() {
      return signedIn() && request.auth.token.firebase.sign_in_provider == "google.com";
    }

    function commentRateLimitDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid)/rateLimits/comments;
    }

    function hasCommentCooldownElapsed(uid) {
      return !exists(commentRateLimitDocPath(uid))
        || (
          get(commentRateLimitDocPath(uid)).data.lastCommentAt is timestamp
          && request.time >= get(commentRateLimitDocPath(uid)).data.lastCommentAt + duration.value(20, "s")
        );
    }

    function hasCommentRateLimitWriteInRequest(uid) {
      return getAfter(commentRateLimitDocPath(uid)).data.lastCommentAt == request.time
        && getAfter(commentRateLimitDocPath(uid)).data.updatedAt == request.time;
    }

    function isValidReplyTarget(guideSlug, sectionId, parentId) {
      return parentId is string
        && exists(/databases/$(database)/documents/guides/$(guideSlug)/sections/$(sectionId)/comments/$(parentId))
        && get(/databases/$(database)/documents/guides/$(guideSlug)/sections/$(sectionId)/comments/$(parentId)).data.parentId == null;
    }

    match /admins/{uid} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /admin/{uid} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && uid == request.auth.uid;
      allow create: if signedInWithGoogle()
        && uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "userId",
          "nicknameNoun",
          "nicknameTag",
          "nicknameChangeCount",
          "createdAt",
          "nicknameUpdatedAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "userId",
          "nicknameNoun",
          "nicknameTag",
          "nicknameChangeCount",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.userId is string
        && request.resource.data.nicknameNoun is string
        && request.resource.data.nicknameNoun.matches("^[A-Za-z가-힣]+$")
        && request.resource.data.nicknameNoun.size() > 0
        && request.resource.data.nicknameNoun.size() <= 12
        && request.resource.data.nicknameTag is string
        && request.resource.data.nicknameTag.size() == 4
        && request.resource.data.nicknameChangeCount == 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.nicknameUpdatedAt == null
        && request.resource.data.updatedAt == request.time;
      allow update: if signedInWithGoogle()
        && uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "userId",
          "nicknameNoun",
          "nicknameTag",
          "nicknameChangeCount",
          "createdAt",
          "nicknameUpdatedAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "userId",
          "nicknameNoun",
          "nicknameTag",
          "nicknameChangeCount",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.nicknameTag == resource.data.nicknameTag
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.nicknameNoun is string
        && request.resource.data.nicknameNoun.matches("^[A-Za-z가-힣]+$")
        && request.resource.data.nicknameNoun.size() > 0
        && request.resource.data.nicknameNoun.size() <= 12
        && request.resource.data.nicknameUpdatedAt == request.time
        && request.resource.data.updatedAt == request.time
        && (
          request.resource.data.nicknameChangeCount is int
          || request.resource.data.nicknameChangeCount is float
        )
        && request.resource.data.nicknameChangeCount
          == (
            (
              (resource.data.nicknameChangeCount is int)
              || (resource.data.nicknameChangeCount is float)
            )
              ? resource.data.nicknameChangeCount
              : 0
          ) + 1
        && (
          (
            (
              (resource.data.nicknameChangeCount is int)
              || (resource.data.nicknameChangeCount is float)
            )
              ? resource.data.nicknameChangeCount
              : 0
          ) == 0
          || (
            resource.data.nicknameUpdatedAt is timestamp
            && request.time >= resource.data.nicknameUpdatedAt + duration.value(7, "d")
          )
        );
      allow delete: if false;
    }

    match /users/{uid}/healerPracticeKeybinds/{healerSlug} {
      allow read: if signedIn() && uid == request.auth.uid;
      allow create, update: if signedInWithGoogle()
        && uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "healerSlug",
          "useClickCasting",
          "showHolyPriestEchoOnRaidFrames",
          "movementKeyPreset",
          "movementCustomKeys",
          "keyboardBindings",
          "clickCastBindings",
          "cooldownSpellOrder",
          "cooldownSecondarySpellOrder",
          "cooldownReserveSpellOrder",
          "specialProcOrder",
          "specialProcOrderKeys",
          "specialProcEnabledKeys",
          "specialProcOverlayIconSizePx",
          "cooldownManagerPrimaryIconSizePx",
          "cooldownManagerPrimaryIconSizeSettingPx",
          "cooldownManagerSecondaryIconSizePx",
          "cooldownManagerSecondaryIconSizeSettingPx",
          "cooldownResourceBarOffsets",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "healerSlug",
          "useClickCasting",
          "keyboardBindings",
          "clickCastBindings",
          "updatedAt"
        ])
        && request.resource.data.healerSlug is string
        && request.resource.data.healerSlug == healerSlug
        && request.resource.data.useClickCasting is bool
        && (
          !request.resource.data.keys().hasAny(["showHolyPriestEchoOnRaidFrames"])
          || request.resource.data.showHolyPriestEchoOnRaidFrames is bool
        )
        && (
          !request.resource.data.keys().hasAny(["movementKeyPreset"])
          || (
            request.resource.data.movementKeyPreset is string
            && request.resource.data.movementKeyPreset.size() > 0
            && request.resource.data.movementKeyPreset.size() <= 16
          )
        )
        && (
          !request.resource.data.keys().hasAny(["movementCustomKeys"])
          || (
            request.resource.data.movementCustomKeys is map
            && request.resource.data.movementCustomKeys.keys().hasOnly(["up", "down", "left", "right"])
            && (
              !request.resource.data.movementCustomKeys.keys().hasAny(["up"])
              || request.resource.data.movementCustomKeys.up is string
            )
            && (
              !request.resource.data.movementCustomKeys.keys().hasAny(["down"])
              || request.resource.data.movementCustomKeys.down is string
            )
            && (
              !request.resource.data.movementCustomKeys.keys().hasAny(["left"])
              || request.resource.data.movementCustomKeys.left is string
            )
            && (
              !request.resource.data.movementCustomKeys.keys().hasAny(["right"])
              || request.resource.data.movementCustomKeys.right is string
            )
          )
        )
        && request.resource.data.keyboardBindings is map
        && request.resource.data.clickCastBindings is map
        && request.resource.data.clickCastBindings.values().hasOnly([
          "",
          "LMB",
          "RMB",
          "SHIFT+LMB",
          "SHIFT+RMB",
          "CTRL+LMB",
          "CTRL+RMB",
          "ALT+LMB",
          "ALT+RMB",
          "MMB",
          "MB4",
          "SHIFT+MB4",
          "CTRL+MB4",
          "ALT+MB4",
          "MB5",
          "SHIFT+MB5",
          "CTRL+MB5",
          "ALT+MB5",
          "WHEELUP",
          "WHEELDOWN",
          "SHIFT+WHEELUP",
          "SHIFT+WHEELDOWN",
          "CTRL+WHEELUP",
          "CTRL+WHEELDOWN",
          "ALT+WHEELUP",
          "ALT+WHEELDOWN"
        ])
        && (
          !request.resource.data.keys().hasAny(["cooldownSpellOrder"])
          || request.resource.data.cooldownSpellOrder is list
        )
        && (
          !request.resource.data.keys().hasAny(["cooldownSecondarySpellOrder"])
          || request.resource.data.cooldownSecondarySpellOrder is list
        )
        && (
          !request.resource.data.keys().hasAny(["cooldownReserveSpellOrder"])
          || request.resource.data.cooldownReserveSpellOrder is list
        )
        && (
          !request.resource.data.keys().hasAny(["specialProcOrder"])
          || request.resource.data.specialProcOrder is list
        )
        && (
          !request.resource.data.keys().hasAny(["specialProcOrderKeys"])
          || request.resource.data.specialProcOrderKeys is list
        )
        && (
          !request.resource.data.keys().hasAny(["specialProcEnabledKeys"])
          || request.resource.data.specialProcEnabledKeys is list
        )
        && (
          !request.resource.data.keys().hasAny(["specialProcOverlayIconSizePx"])
          || (
            request.resource.data.specialProcOverlayIconSizePx is int
            || request.resource.data.specialProcOverlayIconSizePx is float
          )
        )
        && (
          !request.resource.data.keys().hasAny(["cooldownManagerPrimaryIconSizePx"])
          || (
            request.resource.data.cooldownManagerPrimaryIconSizePx is int
            || request.resource.data.cooldownManagerPrimaryIconSizePx is float
          )
        )
        && (
          !request.resource.data.keys().hasAny(["cooldownManagerPrimaryIconSizeSettingPx"])
          || (
            request.resource.data.cooldownManagerPrimaryIconSizeSettingPx is int
            || request.resource.data.cooldownManagerPrimaryIconSizeSettingPx is float
          )
        )
        && (
          !request.resource.data.keys().hasAny(["cooldownManagerSecondaryIconSizePx"])
          || (
            request.resource.data.cooldownManagerSecondaryIconSizePx is int
            || request.resource.data.cooldownManagerSecondaryIconSizePx is float
          )
        )
        && (
          !request.resource.data.keys().hasAny(["cooldownManagerSecondaryIconSizeSettingPx"])
          || (
            request.resource.data.cooldownManagerSecondaryIconSizeSettingPx is int
            || request.resource.data.cooldownManagerSecondaryIconSizeSettingPx is float
          )
        )
        && (
          !request.resource.data.keys().hasAny(["cooldownResourceBarOffsets"])
          || (
            request.resource.data.cooldownResourceBarOffsets is map
            && request.resource.data.cooldownResourceBarOffsets.keys().hasOnly([
              "sectionOrder",
              "holyPowerWidthBonusPx",
              "manaWidthBonusPx",
              "holyPowerOffsetXPx",
              "holyPowerOffsetYPx",
              "manaOffsetXPx",
              "manaOffsetYPx"
            ])
            && (
              !request.resource.data.cooldownResourceBarOffsets.keys().hasAny(["sectionOrder"])
              || request.resource.data.cooldownResourceBarOffsets.sectionOrder is list
            )
            && (
              !request.resource.data.cooldownResourceBarOffsets.keys().hasAny(["holyPowerWidthBonusPx"])
              || (
                request.resource.data.cooldownResourceBarOffsets.holyPowerWidthBonusPx is int
                || request.resource.data.cooldownResourceBarOffsets.holyPowerWidthBonusPx is float
              )
            )
            && (
              !request.resource.data.cooldownResourceBarOffsets.keys().hasAny(["manaWidthBonusPx"])
              || (
                request.resource.data.cooldownResourceBarOffsets.manaWidthBonusPx is int
                || request.resource.data.cooldownResourceBarOffsets.manaWidthBonusPx is float
              )
            )
            && (
              !request.resource.data.cooldownResourceBarOffsets.keys().hasAny(["holyPowerOffsetXPx"])
              || (
                request.resource.data.cooldownResourceBarOffsets.holyPowerOffsetXPx is int
                || request.resource.data.cooldownResourceBarOffsets.holyPowerOffsetXPx is float
              )
            )
            && (
              !request.resource.data.cooldownResourceBarOffsets.keys().hasAny(["holyPowerOffsetYPx"])
              || (
                request.resource.data.cooldownResourceBarOffsets.holyPowerOffsetYPx is int
                || request.resource.data.cooldownResourceBarOffsets.holyPowerOffsetYPx is float
              )
            )
            && (
              !request.resource.data.cooldownResourceBarOffsets.keys().hasAny(["manaOffsetXPx"])
              || (
                request.resource.data.cooldownResourceBarOffsets.manaOffsetXPx is int
                || request.resource.data.cooldownResourceBarOffsets.manaOffsetXPx is float
              )
            )
            && (
              !request.resource.data.cooldownResourceBarOffsets.keys().hasAny(["manaOffsetYPx"])
              || (
                request.resource.data.cooldownResourceBarOffsets.manaOffsetYPx is int
                || request.resource.data.cooldownResourceBarOffsets.manaOffsetYPx is float
              )
            )
          )
        )
        && request.resource.data.updatedAt == request.time;
      allow delete: if signedIn() && uid == request.auth.uid;
    }

    match /users/{uid}/rateLimits/{rateKey} {
      allow read: if signedIn() && uid == request.auth.uid;
      allow create: if signedInWithGoogle()
        && uid == request.auth.uid
        && rateKey == "comments"
        && request.resource.data.keys().hasOnly([
          "lastCommentAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "lastCommentAt",
          "updatedAt"
        ])
        && request.resource.data.lastCommentAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if signedInWithGoogle()
        && uid == request.auth.uid
        && rateKey == "comments"
        && request.resource.data.keys().hasOnly([
          "lastCommentAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "lastCommentAt",
          "updatedAt"
        ])
        && resource.data.lastCommentAt is timestamp
        && request.time >= resource.data.lastCommentAt + duration.value(20, "s")
        && request.resource.data.lastCommentAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /healerPracticeRankings/{mapKey}/difficulties/{difficultyKey}/patches/{patchVersion}/healers/{healerSlug}/entries/{entryId} {
      allow read: if true;
      allow create: if signedInWithGoogle()
        && hasUserProfile()
        && difficultyKey in ["heroic", "mythic", "worldFirstKill"]
        && request.resource.data.keys().hasOnly([
          "authUid",
          "internalUserId",
          "playerLabel",
          "healerSlug",
          "difficultyKey",
          "difficultyLabel",
          "patchVersion",
          "mapKey",
          "mapLabel",
          "score",
          "scoreBreakdown",
          "combatRecordSection",
          "meterSection",
          "runMeta",
          "createdAtClientMs",
          "createdAt"
        ])
        && request.resource.data.keys().hasAll([
          "authUid",
          "playerLabel",
          "healerSlug",
          "difficultyKey",
          "difficultyLabel",
          "patchVersion",
          "mapKey",
          "mapLabel",
          "score",
          "scoreBreakdown",
          "combatRecordSection",
          "meterSection",
          "runMeta",
          "createdAtClientMs",
          "createdAt"
        ])
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.mapKey == mapKey
        && request.resource.data.difficultyKey == difficultyKey
        && request.resource.data.patchVersion == patchVersion
        && request.resource.data.healerSlug is string
        && request.resource.data.healerSlug == healerSlug
        && request.resource.data.playerLabel is string
        && request.resource.data.playerLabel.size() > 0
        && request.resource.data.playerLabel.size() <= 32
        && request.resource.data.difficultyLabel is string
        && request.resource.data.mapLabel is string
        && (
          (request.resource.data.score is int)
          || (request.resource.data.score is float)
        )
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && (
          request.resource.data.internalUserId == null
          || request.resource.data.internalUserId == requesterUserId()
        )
        && request.resource.data.scoreBreakdown is map
        && request.resource.data.combatRecordSection is map
        && request.resource.data.meterSection is map
        && request.resource.data.runMeta is map
        && (
          (request.resource.data.createdAtClientMs is int)
          || (request.resource.data.createdAtClientMs is float)
        )
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /userPublicProfiles/{userId} {
      allow read: if true;
      allow create, update: if signedInWithGoogle()
        && hasUserProfile()
        && userId == requesterUserId()
        && request.resource.data.keys().hasOnly([
          "userId",
          "nicknameNoun",
          "nicknameTag",
          "authUid",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "userId",
          "nicknameNoun",
          "nicknameTag",
          "authUid",
          "updatedAt"
        ])
        && request.resource.data.userId == requesterUserId()
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.nicknameNoun is string
        && request.resource.data.nicknameNoun.matches("^[A-Za-z가-힣]+$")
        && request.resource.data.nicknameNoun.size() > 0
        && request.resource.data.nicknameNoun.size() <= 12
        && request.resource.data.nicknameTag is string
        && request.resource.data.nicknameTag == requesterProfile().nicknameTag
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /guides/{guideSlug}/sections/{sectionId}/comments/{commentId} {
      allow read: if true;
      allow create: if signedInWithGoogle()
        && request.resource.data.keys().hasOnly([
          "text",
          "parentId",
          "authorUserId",
          "authorName",
          "createdAt"
        ])
        && request.resource.data.keys().hasAll([
          "text",
          "authorUserId",
          "authorName",
          "createdAt"
        ])
        && request.resource.data.authorUserId is string
        && hasUserProfile()
        && request.resource.data.authorUserId == requesterUserId()
        && request.resource.data.authorName == requesterDisplayName()
        && request.resource.data.authorName is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 100
        && request.resource.data.createdAt == request.time
        && requesterProfile().createdAt is timestamp
        && request.time >= requesterProfile().createdAt + duration.value(2, "m")
        && hasCommentCooldownElapsed(request.auth.uid)
        && hasCommentRateLimitWriteInRequest(request.auth.uid)
        && (
          request.resource.data.parentId == null
          || isValidReplyTarget(guideSlug, sectionId, request.resource.data.parentId)
        );
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /guides/{guideSlug}/sections/{sectionId}/votes/{voteId} {
      allow read: if true;
      allow create: if signedInWithGoogle()
        && hasUserProfile()
        && requesterProfile().createdAt is timestamp
        && request.time >= requesterProfile().createdAt + duration.value(2, "m")
        && request.resource.data.keys().hasOnly([
          "commentId",
          "uid",
          "value",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "commentId",
          "uid",
          "value",
          "updatedAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.commentId is string
        && request.resource.data.value in [-1, 1]
        && voteId == request.resource.data.commentId + "_" + request.auth.uid
        && request.resource.data.updatedAt == request.time
        && exists(/databases/$(database)/documents/guides/$(guideSlug)/sections/$(sectionId)/comments/$(request.resource.data.commentId));
      allow update: if signedInWithGoogle()
        && hasUserProfile()
        && requesterProfile().createdAt is timestamp
        && request.time >= requesterProfile().createdAt + duration.value(2, "m")
        && request.resource.data.keys().hasOnly([
          "commentId",
          "uid",
          "value",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "commentId",
          "uid",
          "value",
          "updatedAt"
        ])
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.commentId == resource.data.commentId
        && request.resource.data.value in [-1, 1]
        && voteId == request.resource.data.commentId + "_" + request.auth.uid
        && request.resource.data.updatedAt == request.time
        && exists(/databases/$(database)/documents/guides/$(guideSlug)/sections/$(sectionId)/comments/$(request.resource.data.commentId));
      allow delete: if (signedIn() && resource.data.uid == request.auth.uid) || isAdmin();
    }
  }
}
